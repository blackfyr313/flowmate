{
  "name": "flowmate",
  "version": "1.0.0",
  "description": "Windows automation app — build no-code workflows that run automatically",
  "main": "out/main/index.js",
  "author": {
    "name": "Blackfyre",
    "email": "adarshchauhan13@gmail.com"
  },
  "homepage": "https://github.com/blackfyr313/flowmate",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "engine:dev": "cd engine && python main.py",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "axios": "^1.6.8",
    "electron-updater": "^6.1.8",
    "lucide-react": "^0.363.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.3",
    "vite": "^5.2.6"
  },
  "build": {
    "appId": "com.blackfyre.flowmate",
    "productName": "FlowMate",
    "copyright": "© 2025 FlowMate by Blackfyre. All rights reserved.",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico",
      "publisherName": "FlowMate by Blackfyre",
      "legalTrademarks": "FlowMate™ by Blackfyre",
      "executableName": "FlowMate",
      "fileAssociations": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "license": "resources/license.txt",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FlowMate",
      "menuCategory": "FlowMate by Blackfyre",
      "deleteAppDataOnUninstall": false
    },
    "extraResources": [
      {
        "from": "engine",
        "to": "engine",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ]
  }
}
